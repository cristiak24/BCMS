{
  "name": "bcms-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "firebase/functions"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=apps/server\" \"npm run start --workspace=apps/client\"",
    "seed:superadmin": "tsx scripts/seedSuperadmin.ts",
    "functions:build": "npm run build --workspace=firebase/functions",
    "functions:deploy": "npm run build --workspace=firebase/functions && firebase deploy --only functions"
  },
  "devDependencies": {
    "concurrently": "^8.0.0"
  },
  "overrides": {
    "ajv": "^8.17.1"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.1"
  }
}
